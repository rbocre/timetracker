{
  "name": "timetracker",
  "version": "1.1.0",
  "private": true,
  "description": "Stundenerfassungs-App fuer Schweizer IT-Spezialisten",
  "workspaces": [
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev -w packages/backend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "build": "npm run build -w packages/backend && npm run build -w packages/frontend",
    "build:backend": "npm run build -w packages/backend",
    "build:frontend": "npm run build -w packages/frontend",
    "start:prod": "npm run start -w packages/backend",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "npm test -w packages/backend",
    "test:frontend": "npm test -w packages/frontend",
    "lint": "npm run lint -w packages/backend && npm run lint -w packages/frontend",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,css}\"",
    "db:migrate": "npm run db:migrate -w packages/backend",
    "db:seed": "npm run db:seed -w packages/backend",
    "db:studio": "npm run db:studio -w packages/backend",
    "clean": "rimraf packages/*/dist packages/*/coverage packages/*/.tsbuildinfo"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
